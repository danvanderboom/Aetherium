@page "/"
@using Aetherium.Dashboard.Services
@inject AgentTelemetryService TelemetryService
@inject ManagementApiClient ManagementApi
@implements IAsyncDisposable

<PageTitle>Overview</PageTitle>

<h1>Agent Training Overview</h1>

<div class="row">
    <div class="col-md-12">
        <h2>Active Agents</h2>
        <p>Monitor active agents and their training progress.</p>
        <a href="/agent-monitor" class="btn btn-primary">View Agent Monitor</a>
        <a href="/worlds" class="btn btn-secondary ms-2">Manage Worlds & Sessions</a>
    </div>
</div>

<div class="row mt-4">
    <div class="col-md-12">
        <h2>Quick Stats</h2>
        <div class="row">
            <div class="col-md-3">
                <div class="metrics-card">
                    <h3>Active Agents</h3>
                    <div class="value">@(stats?.ActiveAgents ?? 0)</div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="metrics-card">
                    <h3>Active Sessions</h3>
                    <div class="value">@(stats?.ActiveSessions ?? 0)</div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="metrics-card">
                    <h3>Active Worlds</h3>
                    <div class="value">@(stats?.ActiveWorlds ?? 0)</div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="metrics-card">
                    <h3>Total Worlds</h3>
                    <div class="value">@(stats?.TotalWorlds ?? 0)</div>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    private ManagementStats? stats;
    private System.Threading.Timer? refreshTimer;
    private bool disposed = false;

    protected override async Task OnInitializedAsync()
    {
        await LoadStats();
        
        // Refresh stats every 5 seconds
        refreshTimer = new System.Threading.Timer(async _ => await RefreshStats(), null, 
            TimeSpan.FromSeconds(5), TimeSpan.FromSeconds(5));
    }

    private async Task LoadStats()
    {
        try
        {
            stats = await ManagementApi.GetStatsAsync();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading stats: {ex.Message}");
        }
        
        StateHasChanged();
    }

    private async Task RefreshStats()
    {
        if (!disposed)
        {
            await LoadStats();
        }
    }

    public async ValueTask DisposeAsync()
    {
        if (!disposed)
        {
            disposed = true;
            refreshTimer?.Dispose();
        }
        await Task.CompletedTask;
    }
}

