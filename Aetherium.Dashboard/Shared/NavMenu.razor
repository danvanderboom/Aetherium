<div class="top-row ps-3 navbar navbar-dark">
    <div class="container-fluid">
        <a class="navbar-brand" href="">Aetherium Dashboard</a>
        <button title="Navigation menu" class="navbar-toggler" @onclick="ToggleNavMenu">
            <span class="navbar-toggler-icon"></span>
        </button>
    </div>
</div>

<div class="@NavMenuCssClass" @onclick="ToggleNavMenu">
    <nav class="flex-column">
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="" Match="NavLinkMatch.All">
                <span class="bi bi-list-nested" aria-hidden="true"></span> Overview
            </NavLink>
        </div>
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="agent-monitor">
                <span class="bi bi-person" aria-hidden="true"></span> Agent Monitor
            </NavLink>
        </div>
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="performance-analytics">
                <span class="bi bi-graph-up" aria-hidden="true"></span> Performance Analytics
            </NavLink>
        </div>
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="curriculum-progress">
                <span class="bi bi-list-check" aria-hidden="true"></span> Curriculum Progress
            </NavLink>
        </div>
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="benchmark-comparison">
                <span class="bi bi-bar-chart" aria-hidden="true"></span> Benchmark Comparison
            </NavLink>
        </div>
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="replay-viewer">
                <span class="bi bi-play-circle" aria-hidden="true"></span> Replay Viewer
            </NavLink>
        </div>
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="pcg">
                <span class="bi bi-grid-3x3" aria-hidden="true"></span> PCG Editor
            </NavLink>
        </div>
    </nav>
</div>

@code {
    private bool collapseNavMenu = true;

    private string? NavMenuCssClass => collapseNavMenu ? "collapse" : null;

    private void ToggleNavMenu()
    {
        collapseNavMenu = !collapseNavMenu;
    }
}

